[Unit]
Description=Soup Game FastAPI app
After=network.target redis-server.service
Requires=redis-server.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/soup-game
Environment=REDIS_URL=redis://127.0.0.1:6379/0
Environment=PATH=/opt/soup-game/.venv/bin:/usr/local/bin:/usr/bin
ExecStart=/opt/soup-game/.venv/bin/uvicorn soup_game.main:app --host 127.0.0.1 --port 8000 --workers 1
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
